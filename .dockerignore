# Keep the Docker / Cloud Build context small and secret-free. The image COPYs
# scripts/gatekeeper.mjs + asset-service/; everything heavy or sensitive is excluded from the upload.
.git
lib
out
cache
broadcast
docs
.github
.secrets
.env
.env.*
gate-upstreams.json
distribution.json
node_modules
*.log
# Python bytecode (never bake stale pyc into the image)
__pycache__/
*.pyc
