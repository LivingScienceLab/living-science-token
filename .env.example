# Copy this file to ".env" and fill in your values.
# ".env" is gitignored and must NEVER be committed.

# --- Alchemy RPC endpoints ---
# Get keys at https://dashboard.alchemy.com  (create one app per network).
# These are the only secrets needed; signing is done on your Ledger, not here.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# --- Etherscan (for source verification with --verify) ---
# One key works for both mainnet and Sepolia: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# --- Your Ledger address ---
# The Ethereum address from your Ledger that will deploy and receive the full supply.
# This is NOT a secret (it's a public address) but is kept here for convenience.
LEDGER_SENDER=0xYourLedgerAddressHere
